# Managed Neon Auth for the production super-admin login.
NEON_AUTH_BASE_URL=https://your-neon-auth-host/neondb/auth
NEON_AUTH_COOKIE_SECRET=change-me-to-at-least-32-random-characters

# Comma-separated email allowlist. Fail-closed: without this, no Neon account
# can enter the super-admin console.
SUPERADMIN_ALLOWED_EMAILS=you@example.com

# Local development fallback. Disabled automatically in production.
SUPERADMIN_LOCAL_EMAIL=you@example.com
SUPERADMIN_LOCAL_PASSWORD=change-me
SUPERADMIN_LOCAL_SESSION_SECRET=change-me-to-at-least-32-random-characters

SATURN_API_BASE_URL=http://localhost:3002
SATURN_SUPERADMIN_SERVICE_TOKEN=change-me

MERCURY_API_BASE_URL=https://mercuryapi.skymdev.fr
MERCURY_SUPERADMIN_SERVICE_TOKEN=change-me

# Public code observatory. Keep the token server-side and restrict it to the
# repositories that should be visible in the public metrics page.
GITHUB_CODE_METRICS_TOKEN=token
GITHUB_CODE_METRICS_REPOSITORIES=Skym-m/Saturn@main,Skym-m/Mercury@main
GITHUB_CODE_METRICS_CACHE_SECONDS=21600
GITHUB_CODE_METRICS_MAX_FILE_BYTES=1000000
GITHUB_CODE_METRICS_HISTORY_POINTS=8
CODE_METRICS_REFRESH_TOKEN=change-me-server-side-only
